{
  "name": "@hiero-ledger/mirror-rest",
  "version": "0.157.0-SNAPSHOT",
  "description": "Mirror Node REST API",
  "type": "module",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "generate-proto-js": "node scripts/generate-proto-js.mjs",
    "prebuild": "npm run generate-proto-js",
    "build": "node esbuild.config.js",
    "dev": "cross-env HIERO_MIRROR_REST_LOG_LEVEL=trace nodemon --import=extensionless/register server.js",
    "start": "npm run build && node buildDist/server.js",
    "pretest": "node --import=extensionless/register __tests__/integration/generator.js && npm run prebuild",
    "test": "cross-env NODE_NO_WARNINGS=1 node --import=extensionless/register --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "author": "Mirror Node Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@godaddy/terminus": "4.12.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "asn1js": "3.0.10",
    "basic-auth": "2.0.1",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-http-context": "2.0.1",
    "express-openapi-validator": "5.6.2",
    "extend": "3.0.2",
    "ioredis": "5.11.0",
    "js-yaml": "4.1.1",
    "json-bigint": "1.0.0",
    "lodash": "4.18.1",
    "negotiator": "1.0.0",
    "parse-duration": "2.1.6",
    "pg": "8.21.0",
    "pg-range": "1.1.2",
    "qs": "6.15.2",
    "quick-lru": "7.3.0",
    "rfc4648": "1.5.4",
    "sql-formatter": "15.8.0",
    "swagger-ui-express": "5.0.1",
    "tsscmp": "1.0.6"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.70.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@testcontainers/postgresql": "12.0.1",
    "cross-env": "10.1.0",
    "crypto-random-string": "5.0.0",
    "esbuild": "^0.28.0",
    "extensionless": "2.0.6",
    "jest": "30.4.2",
    "jest-extended": "7.0.0",
    "jest-junit": "17.0.0",
    "nodemon": "3.1.14",
    "pg-format": "1.0.4",
    "pgsql-parser": "17.9.15",
    "sinon": "22.0.0",
    "supertest": "7.2.2",
    "tar": "7.5.15"
  },
  "peerDependencies": {
    "ansi-regex": "6.2.2",
    "ansi-styles": "6.2.3",
    "chalk": "5.6.2",
    "debug": "4.4.1",
    "is-arrayish": "0.3.4",
    "strip-ansi": "7.1.2",
    "wrap-ansi": "9.0.2"
  },
  "jest-junit": {
    "outputDirectory": "build/test-results/test",
    "outputName": "TEST-jest.xml"
  },
  "baseUrlPath": "/api/v1",
  "overrides": {
    "brace-expansion": "5.0.6",
    "fast-uri": "3.1.2",
    "glob": "13.0.6",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "3.14.2"
    },
    "multer": "2.1.1",
    "path-to-regexp": "8.4.0",
    "test-exclude": "8.0.0"
  },
  "bundleDependencies": true
}
