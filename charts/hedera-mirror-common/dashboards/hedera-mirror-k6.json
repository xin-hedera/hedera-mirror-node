          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (namespace, scenario, suite) (rate(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\",suite=~\"$suite\"}[$__rate_interval])))",
          "interval": "",
          "legendFormat": "{{scenario}}",
          "range": true,
