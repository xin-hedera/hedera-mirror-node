          "editorMode": "code",
          "expr": "sum by (namespace, scenario, suite) (histogram_sum(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\",suite=~\"$suite\",passed=\"true\"}) / histogram_count(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\",suite=~\"$suite\",passed=\"true\"}))",
